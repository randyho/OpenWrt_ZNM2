# 设备平台
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y

# 设备列表 - 仅支持 ZN M2
CONFIG_TARGET_MULTI_PROFILE=n
CONFIG_TARGET_ROOTFS_INITRAMFS=n
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y

# 无线网络配置
CONFIG_ATH11K_NSS_SUPPORT=n         # 禁用 ATH11K NSS 加速支持
CONFIG_DRIVER_11AC_SUPPORT=n        # 禁用 802.11ac 支持
CONFIG_DRIVER_11AX_SUPPORT=n        # 禁用 802.11ax (WiFi 6) 支持
CONFIG_PACKAGE_hostapd-common=n     # 禁用 hostapd 通用包
CONFIG_PACKAGE_iw=n                 # 禁用 iw 无线工具
CONFIG_PACKAGE_wpad-openssl=n
CONFIG_PACKAGE_hostapd-common=n
CONFIG_PACKAGE_ipq-wifi-zn_m2=n

# 禁用 ATH11K 驱动和固件
CONFIG_PACKAGE_kmod-ath=n
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018-ddwrt=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074-ddwrt=n

# 禁用 MAC80211 和相关模块
CONFIG_PACKAGE_kmod-cfg80211=n
CONFIG_PACKAGE_kmod-mac80211=n
CONFIG_PACKAGE_wifi-scripts=n
CONFIG_PACKAGE_wireless-regdb=n
CONFIG_PACKAGE_wpad-openssl=n

# 内核参数
CONFIG_KERNEL_ARM_PMU=y                       # ARM 性能监控单元
CONFIG_KERNEL_CFQ_GROUP_IOSCHED=y             # CFQ 组 I/O 调度器
CONFIG_KERNEL_CGROUP_DEVICE=y                 # Cgroup 设备控制
CONFIG_KERNEL_CGROUP_FREEZER=y                # Cgroup 冻结器
CONFIG_KERNEL_CGROUP_HUGETLB=n                # 禁用 Cgroup 大页（Docker已移除，不需要）
CONFIG_KERNEL_CGROUP_NET_PRIO=y               # Cgroup 网络优先级
CONFIG_KERNEL_CGROUP_PERF=y                   # Cgroup 性能事件
CONFIG_KERNEL_HUGETLBFS=n                     # 禁用大页文件系统（Docker已移除）
CONFIG_KERNEL_HUGETLB_PAGE=n                  # 禁用大页支持（Docker已移除）
CONFIG_KERNEL_MEMCG_SWAP_ENABLED=n            # 禁用 Swap（路由器通常不需要）
CONFIG_KERNEL_NET_CLS_CGROUP=y                # 网络分类 Cgroup
CONFIG_KERNEL_PERF_EVENTS=y                   # 性能事件支持
CONFIG_KERNEL_PREEMPT_RCU=n                   # 禁用抢占式 RCU
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE=n          # 禁用透明大页（Docker已移除）
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE_ALWAYS=n   # 禁用透明大页（Docker已移除）

# NSS 硬件加速配置
CONFIG_NSS_DRV_IGS_ENABLE=y                   # NSS IGS 支持
CONFIG_NSS_DRV_MAPT_ENABLE=y                  # NSS MAP-T 支持
CONFIG_NSS_DRV_PPTP_ENABLE=y                  # NSS PPTP 支持
CONFIG_NSS_DRV_SHAPER_ENABLE=y                # NSS 流量整形支持
CONFIG_NSS_DRV_WIFIOFFLOAD_ENABLE=n           # 禁用 NSS WiFi 卸载
CONFIG_NSS_FIRMWARE_VERSION_12_2=y            # NSS 固件版本 12.2
CONFIG_NSS_FIRMWARE_VERSION_12_5=n            # 禁用版本 12.5

CONFIG_PACKAGE_kmod-qca-mcs=y                 # QCA 多播转发
CONFIG_PACKAGE_kmod-qca-nss-drv-igs=y         # NSS IGS 驱动
CONFIG_PACKAGE_kmod-qca-nss-drv-map-t=y       # NSS MAP-T 驱动
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y       # NSS PPPoE 驱动
CONFIG_PACKAGE_kmod-qca-nss-drv-pptp=y        # NSS PPTP 驱动
CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc=y       # NSS QDisc 驱动
CONFIG_PACKAGE_kmod-qca-nss-macsec=y          # NSS MACsec 驱动

# Docker 容器支持 (已禁用)
CONFIG_DOCKER_CGROUP_OPTIONS=n                # 禁用 Docker Cgroup 选项
CONFIG_DOCKER_NET_MACVLAN=n                   # 禁用 Docker MACVLAN 网络
CONFIG_DOCKER_OPTIONAL_FEATURES=n             # 禁用 Docker 可选功能
CONFIG_DOCKER_STO_EXT4=n                      # 禁用 Docker EXT4 存储驱动
CONFIG_PACKAGE_containerd=n                   # 禁用 Containerd 容器运行时
CONFIG_PACKAGE_coremark=n                     # 禁用 coremark 性能测试
CONFIG_PACKAGE_docker=n                       # 禁用 Docker 引擎
CONFIG_PACKAGE_docker-compose=n               # 禁用 Docker Compose
CONFIG_PACKAGE_dockerd=n                      # 禁用 Docker 守护进程
CONFIG_PACKAGE_runc=n                         # 禁用 RunC 容器运行时
CONFIG_PACKAGE_tini=n                         # 禁用 Tini init 进程
CONFIG_PACKAGE_cgroupfs-mount=n               # 禁用 Cgroup 文件系统挂载
								              
# 文件系统支持 (已禁用)                       
CONFIG_PACKAGE_btrfs-progs=n                  # 禁用 Btrfs 文件系统工具
CONFIG_PACKAGE_kmod-fs-btrfs=n                # 禁用 Btrfs 内核模块
CONFIG_PACKAGE_kmod-scsi-core=n               # 禁用 SCSI 核心支持
CONFIG_PACKAGE_mount-utils=n                  # 禁用挂载工具

# 加密与安全模块
CONFIG_PACKAGE_kmod-crypto-acompress=y        # 异步压缩
CONFIG_PACKAGE_kmod-crypto-blake2b=y          # BLAKE2b 哈希
CONFIG_PACKAGE_kmod-crypto-kpp=y              # 密钥协议处理器
CONFIG_PACKAGE_kmod-crypto-lib-chacha20=y     # ChaCha20 加密
CONFIG_PACKAGE_kmod-crypto-lib-chacha20poly1305=y  # ChaCha20-Poly1305
CONFIG_PACKAGE_kmod-crypto-lib-curve25519=y   # Curve25519 椭圆曲线
CONFIG_PACKAGE_kmod-crypto-lib-poly1305=y     # Poly1305 MAC
CONFIG_PACKAGE_kmod-crypto-xxhash=y           # xxHash 哈希算法

# 禁用的加密模块
CONFIG_PACKAGE_kmod-crypto-aead=n
CONFIG_PACKAGE_kmod-crypto-ccm=n
CONFIG_PACKAGE_kmod-crypto-cmac=n
CONFIG_PACKAGE_kmod-crypto-ctr=n
CONFIG_PACKAGE_kmod-crypto-gcm=n
CONFIG_PACKAGE_kmod-crypto-gf128=n
CONFIG_PACKAGE_kmod-crypto-ghash=n
CONFIG_PACKAGE_kmod-crypto-hmac=n
CONFIG_PACKAGE_kmod-crypto-manager=n
CONFIG_PACKAGE_kmod-crypto-michael-mic=n
CONFIG_PACKAGE_kmod-crypto-null=n
CONFIG_PACKAGE_kmod-crypto-rng=n
CONFIG_PACKAGE_kmod-crypto-seqiv=n
CONFIG_PACKAGE_kmod-crypto-sha3=n
CONFIG_PACKAGE_kmod-crypto-sha512=n

# 网络功能模块
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_firewall=n
CONFIG_PACKAGE_firewall4=y                    # 使用 firewall4
CONFIG_PACKAGE_ip-full=y                      # 完整版 IP 工具（Tun 模式需要）
CONFIG_PACKAGE_ip-tiny=n                      # 禁用精简版
CONFIG_PACKAGE_ip6tables-nft=y                # IPv6 防火墙 (nftables)
CONFIG_PACKAGE_iptables-mod-extra=y           # iptables 扩展模块
CONFIG_PACKAGE_iptables-nft=y                 # iptables (nftables 后端)
CONFIG_PACKAGE_xtables-nft=y                  # xtables-nft 工具
CONFIG_PACKAGE_kmod-br-netfilter=y            # 网桥 netfilter
CONFIG_PACKAGE_kmod-dummy=y                   # 虚拟网络设备
CONFIG_PACKAGE_kmod-ifb=y                     # IFB 虚拟网络设备
CONFIG_PACKAGE_kmod-inet-diag=y               # 网络诊断
CONFIG_PACKAGE_kmod-ip6tables=y               # IPv6 防火墙表
CONFIG_PACKAGE_kmod-ipt-conntrack=y           # 连接跟踪
CONFIG_PACKAGE_kmod-ipt-core=y                # iptables 核心
CONFIG_PACKAGE_kmod-ipt-extra=y               # iptables 扩展
CONFIG_PACKAGE_kmod-ipt-nat=y                 # NAT 支持
CONFIG_PACKAGE_kmod-ipt-nat6=y                # IPv6 NAT
CONFIG_PACKAGE_kmod-ipt-physdev=y             # 物理设备匹配
CONFIG_PACKAGE_kmod-macvlan=n                 # 禁用 MACVLAN（Docker macvlan，已移除）
CONFIG_PACKAGE_kmod-nat46=y                   # NAT46 转换
CONFIG_PACKAGE_kmod-netlink-diag=y            # Netlink 诊断
CONFIG_PACKAGE_kmod-nf-ipt=y                  # Netfilter IPv4
CONFIG_PACKAGE_kmod-nf-ipt6=y                 # Netfilter IPv6
CONFIG_PACKAGE_kmod-nf-ipvs=n                 # 禁用 IPVS（Docker负载均衡，已移除）
CONFIG_PACKAGE_kmod-nf-nat6=y                 # IPv6 NAT
CONFIG_PACKAGE_kmod-nf-tproxy=y               # 透明代理
CONFIG_PACKAGE_kmod-nft-compat=y              # nftables 兼容层
CONFIG_PACKAGE_kmod-nft-tproxy=y              # nftables 透明代理
CONFIG_PACKAGE_kmod-sched-core=y              # 流量调度核心
CONFIG_PACKAGE_kmod-tun=y                     # TUN/TAP 设备
CONFIG_PACKAGE_kmod-veth=n                    # 禁用 veth（Docker容器网络，已移除）
CONFIG_PACKAGE_kmod-wireguard=n               # 禁用 WireGuard VPN

# USB 支持 (已禁用)
CONFIG_PACKAGE_kmod-usb-dwc2=n                # 禁用 DWC2 USB 控制器
CONFIG_PACKAGE_kmod-usb-dwc2-pci=n            # 禁用 DWC2 PCI 版本
CONFIG_PACKAGE_kmod-usb-ehci=n                # 禁用 EHCI USB 2.0 主控制器
CONFIG_PACKAGE_kmod-usb-ohci=n                # 禁用 OHCI USB 1.1 主控制器
CONFIG_PACKAGE_kmod-usb-phy-nop=n             # 禁用 USB PHY
CONFIG_PACKAGE_kmod-usb-roles=n               # 禁用 USB 角色切换
CONFIG_PACKAGE_kmod-usb-storage=n             # 禁用 USB 存储支持
CONFIG_PACKAGE_kmod-usb-storage-extras=n      # 禁用 USB 存储扩展
CONFIG_PACKAGE_kmod-usb-uhci=n                # 禁用 UHCI USB 控制器
CONFIG_PACKAGE_kmod-usb2=n                    # 禁用 USB 2.0 支持
CONFIG_PACKAGE_kmod-usb2-pci=n                # 禁用 USB 2.0 PCI 支持

# 压缩库支持 (部分禁用，仅保留系统必需)
CONFIG_PACKAGE_kmod-lib-lzo=n                 # 禁用 LZO 压缩
CONFIG_PACKAGE_kmod-lib-raid6=n               # 禁用 RAID6 支持
CONFIG_PACKAGE_kmod-lib-xor=n                 # 禁用 XOR 运算
CONFIG_PACKAGE_kmod-lib-xxhash=y              # xxHash 哈希
CONFIG_PACKAGE_kmod-lib-zlib-deflate=y        # Zlib deflate
CONFIG_PACKAGE_kmod-lib-zlib-inflate=y        # Zlib inflate
CONFIG_PACKAGE_kmod-lib-zstd=n                # 禁用 Zstandard 压缩
CONFIG_PACKAGE_liblzo=n                       # 禁用 LZO 用户空间库

# 系统库文件
CONFIG_PACKAGE_libattr=y                      # 扩展属性库
CONFIG_PACKAGE_libcap=y                       # POSIX 能力库
CONFIG_PACKAGE_libcap-ng=n                    # 禁用下一代能力库（libcap已够用）
CONFIG_PACKAGE_libiptext=y                    # iptables 文本库
CONFIG_PACKAGE_libiptext-nft=y                # nftables 文本库
CONFIG_PACKAGE_libiptext6=y                   # IPv6 文本库
CONFIG_PACKAGE_liblua=y                       # Lua 脚本库
CONFIG_PACKAGE_liblucihttp=y                  # LuCI HTTP 库
CONFIG_PACKAGE_liblucihttp-lua=y              # LuCI HTTP Lua 绑定
CONFIG_PACKAGE_liblucihttp-ucode=y            # LuCI HTTP ucode 绑定
CONFIG_PACKAGE_libmount=n                     # 禁用挂载库（文件系统相关）
CONFIG_PACKAGE_libncurses=n                   # NCurses 终端库
CONFIG_PACKAGE_libseccomp=n                   # 禁用 Seccomp（Docker专用，已移除）
CONFIG_PACKAGE_libubus-lua=y                  # ubus Lua 绑定
CONFIG_PACKAGE_libuv=y                        # 异步 I/O 库
CONFIG_PACKAGE_libwebsockets-full=y           # WebSockets 库
CONFIG_PACKAGE_libxtables=y                   # xtables 库
CONFIG_PACKAGE_libmbedtls=y                   # mbedTLS 加密库

# LuCI Web 界面核心
CONFIG_PACKAGE_lua=y                          # Lua 解释器
CONFIG_PACKAGE_luci=y                         # LuCI 完整包
CONFIG_PACKAGE_luci-base=y                    # LuCI 基础包
CONFIG_PACKAGE_luci-compat=y                  # LuCI 兼容层
CONFIG_PACKAGE_luci-light=y                   # LuCI 轻量版
CONFIG_PACKAGE_luci-lua-runtime=y             # LuCI Lua 运行时

# LuCI 模块
CONFIG_PACKAGE_luci-mod-admin-full=y          # 完整管理界面
CONFIG_PACKAGE_luci-mod-network=y             # 网络管理模块
CONFIG_PACKAGE_luci-mod-status=y              # 状态显示模块
CONFIG_PACKAGE_luci-mod-system=y              # 系统管理模块

# LuCI 库
CONFIG_PACKAGE_luci-lib-base=y                # LuCI 基础库
CONFIG_PACKAGE_luci-lib-docker=n              # 禁用 Docker 管理库
CONFIG_PACKAGE_luci-lib-ip=y                  # IP 地址库
CONFIG_PACKAGE_luci-lib-jsonc=y               # JSON-C 库
CONFIG_PACKAGE_luci-lib-nixio=y               # Nixio I/O 库
CONFIG_PACKAGE_luci-lib-uqr=y                 # 二维码库

# LuCI 协议支持
CONFIG_PACKAGE_luci-proto-ipv6=y              # IPv6 协议
CONFIG_PACKAGE_luci-proto-ppp=y               # PPP 协议
CONFIG_PACKAGE_luci-proto-wireguard=n         # WireGuard 协议

# LuCI 主题
CONFIG_PACKAGE_luci-theme-argon=y             # Argon 主题
CONFIG_PACKAGE_luci-theme-bootstrap=y         # Bootstrap 主题

# ============================================
# LuCI 应用程序
# ============================================
CONFIG_PACKAGE_luci-app-argon-config=n         # 禁用 Argon 主题配置
CONFIG_PACKAGE_luci-app-arpbind=y              # 绑定 IP 和 MAC 地址
CONFIG_PACKAGE_luci-app-athena-led=n           # 禁用 LED 控制（仅RE-CS-02需要）
CONFIG_PACKAGE_luci-app-ddns=n                 # 禁用 动态 DNS 服务
CONFIG_PACKAGE_luci-app-dockerman=n            # 禁用 Docker 管理
CONFIG_PACKAGE_luci-app-filebrowser=n          # 禁用 文件浏览
CONFIG_PACKAGE_luci-app-filemanager=y          # 启用文件管理
CONFIG_PACKAGE_luci-app-firewall=n             # 启用 防火墙管理
CONFIG_PACKAGE_luci-app-homeproxy=n            # 禁用 HomeProxy 代理
CONFIG_PACKAGE_luci-app-msd_lite=n             # 禁用 MSD
CONFIG_PACKAGE_luci-app-mosdns=n               # 禁用 MosDNS 服务
CONFIG_PACKAGE_luci-app-nikki=y                # 启用 OpenWrt Nikki
CONFIG_PACKAGE_luci-app-openclash=n            # 禁用 OpenClash 代理
CONFIG_PACKAGE_luci-app-package-manager=y      # 启用 软件包管理
CONFIG_PACKAGE_luci-app-passwall=n             # 禁用 PassWall 代理
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Haproxy=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Client=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Server=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Simple_Obfs=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Geoview=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Plugin=n
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=n
CONFIG_PACKAGE_luci-app-ssr-plus=n             # 禁用 SSR Plus 代理
CONFIG_PACKAGE_luci-app-smartdns=n             # 禁用 SmartDNS 服务
CONFIG_PACKAGE_luci-app-ttyd=n                 # 禁用 Web 终端
CONFIG_PACKAGE_luci-app-upnp=n                 # 禁用 UPnP 管理
CONFIG_PACKAGE_luci-app-vlmcsd=n               # 禁用 KMS 服务器
CONFIG_PACKAGE_luci-app-wol=n                  # 禁用 网络唤醒
CONFIG_PACKAGE_luci-app-zerotier=n             # 禁用 ZeroTier 虚拟网络

# ============================================
# LuCI 中文语言包
# ============================================
CONFIG_LUCI_LANG_zh_Hans=y                        # 简体中文支持
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=n     # 禁用 Argon 配置（中文）
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y             # 基础中文包
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=n        # 禁用 Docker（中文）
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=n         # 防火墙中文
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=n        # HomeProxy 中文
CONFIG_PACKAGE_luci-i18n-nikki-zh-cn=y            # OpenWrt Nikki 中文
CONFIG_PACKAGE_luci-i18n-package-manager-zh-cn=y  # 软件包管理器中文
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=n             # Web 终端中文
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=n             # UPnP 中文
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=n              # 网络唤醒中文
CONFIG_PACKAGE_luci-i18n-athena-led-zh-cn=n       # 禁用 LED 控制中文

# ============================================
# 网络应用与服务
# ============================================
CONFIG_PACKAGE_chinadns-ng=n                  # ChinaDNS-NG DNS 分流
CONFIG_PACKAGE_nikki=y                        # OpenWrt Nikki 代理工具
CONFIG_PACKAGE_smartdns=n                     # SmartDNS 智能 DNS
CONFIG_PACKAGE_sing-box=n                     # Sing-box 代理工具
CONFIG_PACKAGE_wireguard-tools=n              # WireGuard 工具
CONFIG_PACKAGE_miniupnpd-nftables=n           # MiniUPnPd (nftables)
CONFIG_PACKAGE_etherwake=n                    # 网络唤醒工具



# ============================================
# 系统工具
# ============================================
CONFIG_PACKAGE_ca-certificates=y              # CA 证书
CONFIG_PACKAGE_cgi-io=y                       # CGI I/O 工具
CONFIG_PACKAGE_default-settings=y             # 默认设置
CONFIG_PACKAGE_default-settings-chn=y         # 中国区默认设置
CONFIG_PACKAGE_htop=y                         # 系统监控工具
CONFIG_PACKAGE_terminfo=y                     # 终端信息数据库
CONFIG_PACKAGE_ttyd=n                         # Web 终端守护进程
CONFIG_PACKAGE_resolveip=y                    # IP 解析工具

# ============================================
# RPC 与包管理
# ============================================
CONFIG_USE_APK=y                              # 使用 APK 包管理器
CONFIG_PACKAGE_rpcd=y                         # RPC 守护进程
CONFIG_PACKAGE_rpcd-mod-file=y                # 文件操作模块
CONFIG_PACKAGE_rpcd-mod-iwinfo=y              # 无线信息模块
CONFIG_PACKAGE_rpcd-mod-luci=y                # LuCI 模块
CONFIG_PACKAGE_rpcd-mod-rrdns=y               # 反向 DNS 模块
CONFIG_PACKAGE_rpcd-mod-ucode=y               # ucode 模块

# ============================================
# Web 服务器
# ============================================
CONFIG_PACKAGE_uhttpd=y                       # uHTTPd Web 服务器
CONFIG_PACKAGE_uhttpd-mod-ubus=y              # ubus 集成模块

# ============================================
# ucode 模块
# ============================================
CONFIG_PACKAGE_ucode-mod-html=y               # HTML 模块
CONFIG_PACKAGE_ucode-mod-lua=y                # Lua 模块
CONFIG_PACKAGE_ucode-mod-math=y               # 数学模块
CONFIG_PACKAGE_ucode-mod-digest=n             # 禁用摘要模块
CONFIG_PACKAGE_ucode-mod-nl80211=n            # 禁用无线模块
CONFIG_PACKAGE_ucode-mod-rtnl=n               # 禁用路由模块
CONFIG_PACKAGE_ucode-mod-uloop=n              # 禁用 uloop 模块

# ============================================
# 其他的包
# ============================================
CONFIG_PACKAGE_apk-mbedtls=y                  # 启用 APK (mbedTLS)
CONFIG_PACKAGE_apk-openssl=n                  # 禁用 APK (OpenSSL)
CONFIG_PACKAGE_kmod-hwmon-core=n              # 禁用硬件监控
CONFIG_PACKAGE_kmod-i2c-core=n                # 禁用 I2C
CONFIG_PACKAGE_kmod-mhi-bus=n                 # 禁用 MHI 总线
CONFIG_PACKAGE_kmod-qrtr-mhi=n                # 禁用 QRTR MHI
CONFIG_PACKAGE_kmod-qrtr-smd=n                # 禁用 QRTR SMD
CONFIG_PACKAGE_libopenssl-conf=n              # 禁用 OpenSSL 配置
CONFIG_PACKAGE_libopenssl-legacy=n            # 禁用 OpenSSL 旧版

# ============================================
# mbedTLS 加密库配置
# ============================================
CONFIG_MBEDTLS_AES_C=y                        # AES 加密
CONFIG_MBEDTLS_ARIA_C=n                       # 禁用 ARIA
CONFIG_MBEDTLS_CAMELLIA_C=n                   # 禁用 Camellia
CONFIG_MBEDTLS_CCM_C=n                        # 禁用 CCM 模式
CONFIG_MBEDTLS_CIPHER_MODE_OFB=n              # 禁用 OFB 模式
CONFIG_MBEDTLS_CIPHER_MODE_XTS=n              # 禁用 XTS 模式
CONFIG_MBEDTLS_CMAC_C=y                       # CMAC 消息认证码
CONFIG_MBEDTLS_DEBUG_C=n                      # 禁用调试
CONFIG_MBEDTLS_DEPRECATED_WARNING=n           # 禁用弃用警告
CONFIG_MBEDTLS_DES_C=y                        # DES 加密
